{
	"version": 2,
	"functions": {
		"src/app/**/*.tsx": {
			"memory": 1024
		}
	},
	"env": {
		"TMPDIR": "/tmp"
	},
	"headers": [
		{
			"source": "/tree-sitter/(.*).wasm",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/wasm"
				},
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	]
}
