{
	"name": "git-insights-analyzer",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/Its-Satyajit/git-insights-analyzer.git"
	},
	"bugs": {
		"url": "https://github.com/Its-Satyajit/git-insights-analyzer/issues"
	},
	"scripts": {
		"build": "next build",
		"check": "biome check .",
		"check:unsafe": "biome check --write --unsafe .",
		"check:write": "biome check --write .",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio",
		"dev:next": "INNGEST_DEV=1 next dev",
		"dev:inngest": "inngest-cli dev",
		"dev": "concurrently -n NEXT,INNGEST -c green,blue \"npm run dev:next\" \"npm run dev:inngest\"",
		"preview": "next build && next start",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
