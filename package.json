{
  "name": "git-insights",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Its-Satyajit/git-insights-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/Its-Satyajit/git-insights-analyzer/issues"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio",
    "android:emulator": "pnpm --filter @git-insights/mobile android:emulator"
  },
  "devDependencies": {
    "turbo": "^2.9.8"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3"
    }
  },
  "packageManager": "pnpm@10.33.2"
}