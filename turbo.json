{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env",
    ".env.local",
    ".env.production"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**", ".expo/**"],
      "env": [
        "DATABASE_URL",
        "GITHUB_PAT",
        "REDIS_URL",
        "REDIS_HOST",
        "REDIS_PORT",
        "REDIS_PASSWORD",
        "IDRIVE_E2_ACCESS_KEY",
        "IDRIVE_E2_SECRET_KEY",
        "IDRIVE_E2_BUCKET_NAME",
        "IDRIVE_E2_REGION",
        "IDRIVE_E2_ENDPOINT",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_GITHUB_CLIENT_ID",
        "BETTER_AUTH_GITHUB_CLIENT_SECRET",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "NEXT_PUBLIC_BASE_URL",
        "NEXT_PUBLIC_AI_ENABLED",
        "TMPDIR",
        "VERCEL_URL",
        "VERCEL_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "test:run": {
      "dependsOn": ["^test:run"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}