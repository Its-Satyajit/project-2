# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# Better Auth
# Secret used by Better Auth
BETTER_AUTH_SECRET=""

# Better Auth GitHub OAuth (Optional, if using OAuth instead of PAT)
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""

# Drizzle (Database)
DATABASE_URL="postgresql://postgres:password@localhost:5432/git-insights"

# GitHub Access
# A Personal Access Token (classic or fine-grained) with repo scopes
GITHUB_PAT=""

# Redis (for Analysis Queue)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# App URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
