{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:all",
    "schedule:weekends",
    "automerge:all"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchPackagePatterns": ["^@types/", "^@testing-library/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchDepTypes": ["devDependencies"],
      "extends": ["schedule:weekly"]
    }
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "schedule": ["after 10pm on Saturday", "before 8am on Sunday"],
  "baseBranches": ["main"],
  "labels": ["dependencies", "renovate"],
  "rangeStrategy": "bump",
  "prCreation": "immediate",
  "minimumReleaseAge": "3d",
  "vulnerabilityAlerts": {
    "labels": ["security"]
  }
}
